<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>JSON Hierarchy Mapper (Full Data)</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f8f9fa; padding: 40px; color: #333; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .upload-section { text-align: center; border-bottom: 2px solid #eee; padding-bottom: 30px; margin-bottom: 30px; }
        .upload-btn { background: #e67e22; color: white; padding: 12px 25px; border-radius: 6px; cursor: pointer; display: inline-block; font-weight: bold; }
        #fileInput { display: none; }
        .preview-container { overflow-x: auto; margin-top: 20px; max-height: 600px; }
        table { border-collapse: collapse; width: 100%; font-size: 13px; font-family: 'Courier New', Courier, monospace; }
        td { border: 1px solid #dee2e6; padding: 8px 15px; min-width: 120px; white-space: nowrap; }
        th { background: #f1f1f1; padding: 10px; border: 1px solid #dee2e6; text-align: left; position: sticky; top: 0; }
        .node-text { font-weight: 600; color: #d35400; }
        .index-text { color: #7f8c8d; font-weight: bold; }
        .value-text { color: #2980b9; font-style: italic; }
        .empty-cell { background-color: #ffffff; }
        #status { margin-top: 15px; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="upload-section">
        <h2>JSON Full Data Mapper</h2>
        <p>Upload a JSON file. This version iterates through <b>all array items</b> (e.g., every account).</p>
        <label for="fileInput" class="upload-btn">Upload JSON File</label>
        <input type="file" id="fileInput" accept=".json" onchange="processJSON()">
        <div id="status"></div>
    </div>

    <div class="preview-container">
        <h3>Preview (All Records)</h3>
        <table id="previewTable"></table>
    </div>
</div>

<script>
    function processJSON() {
        const fileInput = document.getElementById('fileInput');
        const status = document.getElementById('status');
        const table = document.getElementById('previewTable');
        const file = fileInput.files[0];

        if (!file) return;

        const reader = new FileReader();
        status.innerHTML = "Processing all records...";
        table.innerHTML = ""; 

        reader.onload = function(e) {
            try {
                const jsonData = JSON.parse(e.target.result);
                const rows = [];
                let maxDepth = 0;

                function traverse(data, depth) {
                    if (depth > maxDepth) maxDepth = depth;

                    if (Array.isArray(data)) {
                        // FIX: Iterate through every single element in the array
                        data.forEach((item, index) => {
                            rows.push({
                                depth: depth,
                                key: `Item [${index}]`,
                                value: "",
                                isIndex: true
                            });
                            traverse(item, depth + 1);
                        });
                    } else if (typeof data === 'object' && data !== null) {
                        Object.keys(data).forEach(key => {
                            const val = data[key];
                            const isObject = typeof val === 'object' && val !== null;
                            
                            rows.push({
                                depth: depth,
                                key: key,
                                value: isObject ? "" : String(val),
                                isIndex: false
                            });

                            if (isObject) {
                                traverse(val, depth + 1);
                            }
                        });
                    }
                }

                traverse(jsonData, 0);

                // Prepare Data for Excel
                const excelData = rows.map(r => {
                    let arr = new Array(maxDepth + 2).fill(""); 
                    arr[r.depth] = r.key;
                    arr[maxDepth + 1] = r.value; 
                    return arr;
                });

                // 1. Generate Excel
                const worksheet = XLSX.utils.aoa_to_sheet(excelData);
                const workbook = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(workbook, worksheet, "Full JSON Data");
                XLSX.writeFile(workbook, "full_response_data.xlsx");

                // 2. Display Preview Table
                let header = "<thead><tr>";
                for(let i=0; i<=maxDepth; i++) header += `<th>Level ${i}</th>`;
                header += "<th>Value</th></tr></thead><tbody id='tableBody'></tbody>";
                table.innerHTML = header;

                const tableBody = document.getElementById('tableBody');
                
                // Note: If JSON is massive, we only preview first 500 rows to prevent browser crash
                const previewLimit = Math.min(rows.length, 500);
                
                for(let i=0; i < previewLimit; i++) {
                    const r = rows[i];
                    const tr = document.createElement('tr');
                    
                    for(let j=0; j <= maxDepth + 1; j++) {
                        const td = document.createElement('td');
                        if (j === r.depth) {
                            const className = r.isIndex ? 'index-text' : 'node-text';
                            td.innerHTML = `<span class="${className}">${r.key}</span>`;
                        } else if (j === maxDepth + 1 && r.value !== "") {
                            td.innerHTML = `<span class="value-text">${r.value}</span>`;
                        } else {
                            td.className = "empty-cell";
                        }
                        tr.appendChild(td);
                    }
                    tableBody.appendChild(tr);
                }

                if(rows.length > 500) {
                    status.innerHTML = `<span style='color:green;'>✅ Success! Excel contains all ${rows.length} rows. (Preview limited to 500).</span>`;
                } else {
                    status.innerHTML = "<span style='color:green;'>✅ Success! All data processed.</span>";
                }

            } catch (err) {
                console.error(err);
                status.innerHTML = "<span style='color:red;'>Error: " + err.message + "</span>";
            }
        };

        reader.readAsText(file);
    }
</script>

</body>
</html>
