<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>XML Mapper - Multiple Records</title>
    <script src="https://cdn.sheetjs.com/xlsx-0.20.1/package/dist/xlsx.full.min.js"></script>
    <style>
        body { font-family: 'Segoe UI', sans-serif; background-color: #f8f9fa; padding: 40px; color: #333; }
        .container { max-width: 1200px; margin: auto; background: white; padding: 30px; border-radius: 12px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }
        .upload-section { text-align: center; border-bottom: 2px solid #eee; padding-bottom: 30px; margin-bottom: 30px; }
        .upload-btn { background: #007bff; color: white; padding: 12px 25px; border-radius: 6px; cursor: pointer; display: inline-block; font-weight: bold; }
        #fileInput { display: none; }
        .preview-container { overflow-x: auto; margin-top: 20px; max-height: 500px; border: 1px solid #ddd; }
        table { border-collapse: collapse; width: 100%; font-size: 13px; font-family: 'Courier New', Courier, monospace; }
        th { background: #e9ecef; text-align: left; padding: 10px; border: 1px solid #dee2e6; position: sticky; top: 0; }
        td { border: 1px solid #dee2e6; padding: 6px 12px; min-width: 120px; }
        .node-text { font-weight: 600; color: #0056b3; }
        .value-text { color: #28a745; font-weight: bold; }
        .index-text { color: #e67e22; font-size: 11px; margin-left: 4px; }
        .empty-cell { background-color: #ffffff; }
        #status { margin-top: 15px; font-weight: bold; }
    </style>
</head>
<body>

<div class="container">
    <div class="upload-section">
        <h2>SOAP/XML Multi-Record Mapper</h2>
        <p>This version identifies repeating elements and captures <b>all records</b>.</p>
        <label for="fileInput" class="upload-btn">Upload XML File</label>
        <input type="file" id="fileInput" accept=".xml" onchange="processXML()">
        <div id="status"></div>
    </div>

    <div class="preview-container">
        <table id="previewTable"></table>
    </div>
</div>

<script>
    function processXML() {
        const fileInput = document.getElementById('fileInput');
        const status = document.getElementById('status');
        const table = document.getElementById('previewTable');
        const file = fileInput.files[0];

        if (!file) return;

        const reader = new FileReader();
        status.innerHTML = "Processing all records...";
        table.innerHTML = ""; 

        reader.onload = function(e) {
            try {
                const xmlText = e.target.result;
                const parser = new DOMParser();
                const xmlDoc = parser.parseFromString(xmlText, "text/xml");

                if (xmlDoc.getElementsByTagName("parsererror").length > 0) {
                    throw new Error("Invalid XML file format.");
                }

                const rows = [];
                let maxDepth = 0;

                function traverse(node, depth) {
                    if (node.nodeType === 1) { // Element Node
                        if (depth > maxDepth) maxDepth = depth;
                        
                        // Check if this node has siblings with the same name (is part of a list)
                        const siblings = Array.from(node.parentNode ? node.parentNode.children : []);
                        const sameNameSiblings = siblings.filter(s => s.localName === node.localName);
                        let displayName = node.localName;
                        
                        if (sameNameSiblings.length > 1) {
                            const index = sameNameSiblings.indexOf(node) + 1;
                            displayName += ` [${index}]`; // Mark record index
                        }

                        // Determine value: only if it's a leaf node with text
                        let value = "";
                        const children = Array.from(node.childNodes);
                        const hasNoElementChildren = !children.some(c => c.nodeType === 1);
                        
                        if (hasNoElementChildren && node.textContent.trim() !== "") {
                            value = node.textContent.trim();
                        }
                        
                        rows.push({
                            depth: depth,
                            name: displayName,
                            value: value
                        });

                        // Recurse to children
                        for (let child of node.children) {
                            traverse(child, depth + 1);
                        }
                    }
                }

                traverse(xmlDoc.documentElement, 0);

                // Prepare Data for Excel
                const finalData = rows.map(r => {
                    let arr = new Array(maxDepth + 2).fill("");
                    arr[r.depth] = r.name;
                    arr[maxDepth + 1] = r.value;
                    return arr;
                });

                // 1. Generate Excel
                const worksheet = XLSX.utils.aoa_to_sheet(finalData);
                const workbook = XLSX.utils.book_new();
                XLSX.utils.book_append_sheet(workbook, worksheet, "XML Full Data");
                XLSX.writeFile(workbook, "xml_full_records.xlsx");

                // 2. Display Preview
                let thead = "<thead><tr>";
                for(let i=0; i<=maxDepth; i++) thead += `<th>Level ${i}</th>`;
                thead += "<th>Value</th></tr></thead>";
                table.innerHTML = thead;

                const tbody = document.createElement('tbody');
                // Preview limited to 300 rows for speed
                finalData.slice(0, 300).forEach(rowData => {
                    const tr = document.createElement('tr');
                    rowData.forEach((cellData, index) => {
                        const td = document.createElement('td');
                        const isValueCol = (index === maxDepth + 1);
                        if (cellData) {
                            td.innerHTML = `<span class="${isValueCol ? 'value-text' : 'node-text'}">${cellData}</span>`;
                        }
                        tr.appendChild(td);
                    });
                    tbody.appendChild(tr);
                });
                table.appendChild(tbody);

                status.innerHTML = `<span style='color:green;'>✅ Success! Processed all records. Excel downloaded.</span>`;
            } catch (err) {
                status.innerHTML = `<span style='color:red;'>Error: ${err.message}</span>`;
            }
        };

        reader.readAsText(file);
    }
</script>

</body>
</html>
