Coding Question 1 (Very Good Interview Question)

Write a C# program to find even numbers from a list using LINQ

Expected Answer:

using System;
using System.Collections.Generic;
using System.Linq;

class Program
{
    static void Main()
    {
        List<int> numbers = new List<int> {1,2,3,4,5,6,7,8};

        var evenNumbers = numbers.Where(n => n % 2 == 0);

        foreach(var num in evenNumbers)
        {
            Console.WriteLine(num);
        }
    }
}

Output

2
4
6
8


